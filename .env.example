# ── Backend de Hacktrack (OPT-IN) ───────────────────────────────────────────────
# Copia este archivo a `.env` y llena los valores para ACTIVAR auth + sync + push.
# Sin estas variables, la app corre 100% local (mocks intactos) — el beta de hoy no cambia.
# Las variables VITE_* se hornean en el bundle del cliente (son públicas; NO pongas secretos aquí).

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push — clave VAPID PÚBLICA (genera el par con: npx web-push generate-vapid-keys)
# La PRIVADA va como secreto del Edge Function (NO aquí): supabase secrets set VAPID_PRIVATE_KEY=...
VITE_VAPID_PUBLIC_KEY=
